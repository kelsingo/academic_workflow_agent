# ═══════════════════════════════════════════════════════════════════════════
# GMAIL SMTP CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

# Your Gmail address
SENDER_EMAIL=

# App Password (NOT your Gmail password):
#   Google Account → Security → 2-Step Verification (enable) → App Passwords
#   Select "Mail" → Generate → copy the 16-char password below
SENDER_PASSWORD=

# ═══════════════════════════════════════════════════════════════════════════
# LLM API CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

GEMINI_API_KEY=your_gemini_api_key_here

# ═══════════════════════════════════════════════════════════════════════════
# APPLICATION EMAILS
# ═══════════════════════════════════════════════════════════════════════════
REGISTRAR_EMAIL=